{
  "manifest_version": 3,
  "name": "Cammino — Job Capture",
  "version": "1.0.0",
  "description": "Save job listings to your Cammino tracker in one click, right from the job page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Cammino",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
